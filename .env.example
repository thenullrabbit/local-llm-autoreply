# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Meta / Instagram ──────────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your-long-lived-instagram-access-token
INSTAGRAM_USER_ID=your-instagram-numeric-user-id
META_APP_SECRET=your-meta-app-secret
VERIFY_TOKEN=thenullrabbit_webhook_2026

# ── Email / Gmail (IMAP + SMTP) ───────────────────────────────────────────────
# Enable IMAP in Gmail: Settings → See all settings → Forwarding and POP/IMAP
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password   # Get from: myaccount.google.com/apppasswords
YOUR_NAME=thenullrabbit

# ── Fallback replies (used when Ollama fails or is offline) ───────────────────
FALLBACK_INSTAGRAM=Hey! Thanks for your comment 👋 I'll get back to you soon.
FALLBACK_EMAIL=Thanks for reaching out! I've received your message and will get back to you shortly.\n\nthenullrabbit

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Worker ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=30          # Instagram Supabase poll interval
EMAIL_POLL_INTERVAL_SECONDS=120   # Email IMAP poll interval (2 minutes)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
